# ─── MongoDB ────────────────────────────────────────────────────────────────
# Get your URI from MongoDB Atlas → Connect → Drivers
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/fedorg?retryWrites=true&w=majority

# ─── JWT ────────────────────────────────────────────────────────────────────
# Change this to a long random string in production
JWT_SECRET=fedorg_super_secret_jwt_key_change_in_production

# ─── Optional: Supabase (leave blank if using MongoDB) ──────────────────────
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
